# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Coolify API
COOLIFY_API_URL=https://app.coolify.io
COOLIFY_API_TOKEN=your_coolify_api_token_here

# Redis (опционально — отключает rate-limit если не указан)
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite+aiosqlite:///app/data/bot.db

# Admin
ADMIN_IDS=123456789,987654321

# Bot config
LOG_LEVEL=INFO
CONFIRM_SECRET_KEY=change_me_to_a_random_string
CONFIRM_TTL_SECONDS=45
RATE_LIMIT_PER_MINUTE=10
RESTART_COOLDOWN_SECONDS=120
LOGS_DEFAULT_LINES=50
